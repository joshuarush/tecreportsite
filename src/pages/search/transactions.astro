---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Transaction Search" description="Search Texas campaign finance contributions and expenditures">
  <div class="bg-slate-50 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="mb-8">
        <nav class="text-sm text-slate-500 mb-2">
          <a href="/" class="hover:text-texas-blue">Home</a>
          <span class="mx-2">›</span>
          <span class="text-slate-900">Transaction Search</span>
        </nav>
        <h1 class="text-3xl font-bold text-slate-900">Transaction Search</h1>
        <p class="text-slate-600 mt-2">
          This page is kept for older links. For useful searches, start with the focused lookup that matches what you need.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <a href="/search/contributors" class="bg-white rounded-xl border border-slate-200 p-5 hover:border-texas-blue transition-colors">
          <h2 class="font-semibold text-slate-900">Donor Lookup</h2>
          <p class="text-sm text-slate-600 mt-2">Search contributions by donor name.</p>
        </a>
        <a href="/search/payees" class="bg-white rounded-xl border border-slate-200 p-5 hover:border-texas-blue transition-colors">
          <h2 class="font-semibold text-slate-900">Payee Lookup</h2>
          <p class="text-sm text-slate-600 mt-2">Search expenditures by vendor or payee.</p>
        </a>
        <a href="/advanced" class="bg-white rounded-xl border border-slate-200 p-5 hover:border-texas-blue transition-colors">
          <h2 class="font-semibold text-slate-900">List Builder</h2>
          <p class="text-sm text-slate-600 mt-2">Build filtered contribution or expenditure lists.</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
